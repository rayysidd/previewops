# frontend/.env.example → copy to frontend/.env.local for local dev
# These are inlined at build time by Vite (never shipped as a file)

# Bridge API URL — leave blank in prod (vite.config.js proxies /api → :4000 in dev)
VITE_BRIDGE_API_URL=http://localhost:4000

# Preview URL template — matches your Ingress host pattern
# {id} is replaced with the BUILD_NUMBER at runtime
VITE_PREVIEW_BASE_URL=http://env-{id}.previewops.local
